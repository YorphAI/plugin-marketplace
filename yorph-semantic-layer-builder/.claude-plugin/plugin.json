  },
  "workflow": {
    "system_prompt_file": "prompts/system.md",
    "steps": [
      {
        "id": "data_source_connection",
        "order": 1,
        "type": "connector_setup",
        "skill_file": "skills/connect/SKILL.md",
        "title": "Connect Your Data Source",
        "required": true,
        "supported_sources": [
          "snowflake", "bigquery", "redshift",
          "sql_server", "supabase", "postgres", "google_cloud_storage", "s3"
        ]
      },
      {
        "id": "industry_and_data_context",
        "order": 2,
        "type": "guided_input",
        "skill_file": "skills/onboarding/SKILL.md",
        "title": "Industry & Data Context",
        "required": true
      },
      {
        "id": "document_upload",
        "order": 3,
        "type": "document_ingestion",
        "skill_file": "skills/document-upload/SKILL.md",
        "title": "Upload Supporting Documents",
        "required": false,
        "accepted_types": [
          "data_dictionary",
          "saas_app_context",
          "business_context",
          "existing_semantic_layer"
        ],
        "accepted_formats": ["pdf", "csv", "json", "yaml", "xlsx", "txt", "md"]
      },
      {
        "id": "output_format_selection",
        "order": 4,
        "type": "format_selection",
        "skill_file": "skills/format-selection/SKILL.md",
        "title": "Choose Output Format",
        "required": true,
        "options": [
          { "id": "dbt",      "label": "dbt",            "schema_file": "schemas/dbt.yaml" },
          { "id": "snowflake","label": "Snowflake",       "schema_file": "schemas/snowflake.yaml" },
          { "id": "json",     "label": "JSON",            "schema_file": "schemas/json.json" },
          { "id": "yaml",     "label": "YAML",            "schema_file": "schemas/yaml.yaml" },
          { "id": "osi_spec", "label": "OSI Spec",        "schema_file": "schemas/osi_spec.yaml" },
          { "id": "document", "label": "Document",        "schema_file": "schemas/document.md" },
          { "id": "custom",   "label": "Custom",          "schema_file": null }
        ]
      },
      {
        "id": "semantic_layer_build",
        "order": 5,
        "type": "dag_agent_build",
        "skill_file": "skills/build/SKILL.md",
        "title": "Building Your Semantic Layer",
        "required": true,
        "dag_config": "runtime/agents/dag.yaml",
        "orchestrator": "runtime/agents/orchestrator.py",
        "tiers": {
          "0": ["schema_annotator", "quality_sentinel", "scd_detector"],
          "1": ["join_validator", "measure_builder", "granularity_definer", "business_rules", "glossary_builder", "time_intelligence", "dimension_hierarchies"]
        },
        "cross_validation": true,
        "on_conflict": {
          "strategy": "ask_user",
          "prompt_file": "prompts/clarification.md"
        }
      },
      {
        "id": "recommendations",
        "order": 6,
        "type": "output",
        "skill_file": "skills/recommendations/SKILL.md",
        "title": "Your Semantic Layer Recommendations",
        "count": 3
      }
    ]
  }
}
