        "auth_methods": {
          "access_key": {
            "label": "Access Key & Secret",
            "fields": [
              { "id": "AWS_ACCESS_KEY_ID",     "label": "Access Key ID",     "type": "text",     "placeholder": "AKIAIOSFODNN7EXAMPLE", "required": true },
              { "id": "AWS_SECRET_ACCESS_KEY", "label": "Secret Access Key", "type": "password", "placeholder": "••••••••",             "required": true },
              { "id": "AWS_REGION",            "label": "Region",            "type": "select",   "options": ["us-east-1", "us-west-2", "eu-west-1", "ap-southeast-1"], "default": "us-east-1", "required": true }
            ]
          },
          "aws_profile": {
            "label": "AWS Profile (local config)",
            "fields": [
              { "id": "AWS_PROFILE", "label": "Profile Name", "type": "text",   "placeholder": "default",  "required": true },
              { "id": "AWS_REGION",  "label": "Region",       "type": "select", "options": ["us-east-1", "us-west-2", "eu-west-1", "ap-southeast-1"], "default": "us-east-1", "required": true }
            ]
          }
