              { "id": "MSSQL_SERVER",   "label": "Server / Host",   "type": "text",     "placeholder": "myserver.database.windows.net", "required": true },
              { "id": "MSSQL_DATABASE", "label": "Database Name",   "type": "text",     "placeholder": "my_database",                   "required": true },
              { "id": "MSSQL_USER",     "label": "Username",         "type": "text",     "placeholder": "sa",                            "required": true },
