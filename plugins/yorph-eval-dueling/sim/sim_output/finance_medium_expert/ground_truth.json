  "expected_measures": [
    {
      "measure_id": "consolidated_revenue",
      "label": "Consolidated Revenue",
      "aggregation": "SUM",
      "source_table": "journal_entries",
      "source_column": "amount",
      "filters": [
        "account_type='revenue'",
        "entry_type!='elimination'",
        "entry_type!='reversal'"
      ],
      "domain": "P&L"
    },
    {
      "measure_id": "ap_outstanding",
      "label": "AP Outstanding",
      "aggregation": "SUM",
      "source_table": "ap_invoices",
      "source_column": "amount_due",
      "filters": [
        "status='open'"
      ],
      "domain": "AP"
    },
    {
      "measure_id": "ar_outstanding",
      "label": "AR Outstanding",
      "aggregation": "SUM",
      "source_table": "ar_invoices",
      "source_column": "amount_due",
      "filters": [
        "status='open'"
      ],
      "domain": "AR"
    },
    {
      "measure_id": "budget_variance",
      "label": "Budget Variance $",
      "aggregation": "SUM",
      "source_table": "budget_vs_actuals",
      "source_column": "variance_amount",
      "filters": [],
      "domain": "Budget"
    },
    {
      "measure_id": "budget_variance_pct",
      "label": "Budget Variance %",
      "aggregation": "AVG",
      "source_table": "budget_vs_actuals",
      "source_column": "variance_pct",
      "filters": [],
      "domain": "Budget"
    }
  ],
  "business_rules": [
    "ALWAYS exclude entry_type='elimination' from consolidated P&L to avoid double-counting.",
    "ALWAYS exclude entry_type='reversal' from period totals.",
    "Multi-currency: use COALESCE(amount_usd, amount) to normalise all amounts to USD.",
    "AP outstanding = sum of ap_invoices.amount_due WHERE status='open'.",
    "AR DSO = AR outstanding / (annual revenue / 365)."
  ],
  "open_questions": [
    "Which entities are in scope for consolidation?",
    "Should budget comparisons use the original budget or the latest reforecast?",
    "Is revenue recognised on invoice date or cash receipt date?"
  ],
